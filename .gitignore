# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Data files (keep structure, ignore large data)
data/raw/*.csv
data/raw/*.json
data/raw/backups/
data/exports/
data/processed/
data/*.db

# Keep sample data
!data/raw/.gitkeep

# Outputs (generated files)
outputs/visualizations/*.png
outputs/reports/*.json
outputs/reports/*.html
outputs/reports/*.pdf

# Keep directory structure
!outputs/visualizations/.gitkeep
!outputs/reports/.gitkeep

# Config with secrets
config/settings.yaml
config/user_profile.json
config/alerts/

# Keep sample config
!config/settings.example.yaml

# Temporary files
*.tmp
*.temp
*~

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Distribution
dist/
build/
*.egg-info/
